  m_Script: {fileID: 11500000, guid: 0184bb0e6d60d664fb460ef3950717ee, type: 3}
  m_Name: duy_quest_2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueID: duy_quest_2
  lines:
  - speakerName: Duy
    text: Okay, thanks.
    portrait: {fileID: 21300000, guid: ac69cb07e8694a240812a39b74b2330b, type: 3}
    setFlagAfter: 
    triggerQuestID: 
  - speakerName: Duy
    text: Now catch 7 eels for me.
    portrait: {fileID: 21300000, guid: ac69cb07e8694a240812a39b74b2330b, type: 3}
    setFlagAfter: 
    triggerQuestID: 
  - speakerName: Duy
    text: They only appear at night.
    portrait: {fileID: 21300000, guid: ac69cb07e8694a240812a39b74b2330b, type: 3}
    setFlagAfter: 
    triggerQuestID: 
  - speakerName: Duy
    text: Come back to me when you're done.
    portrait: {fileID: 21300000, guid: ac69cb07e8694a240812a39b74b2330b, type: 3}
    setFlagAfter: 
    triggerQuestID: quest_3
