%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0184bb0e6d60d664fb460ef3950717ee, type: 3}
  m_Name: goldfish_dialogue_2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueID: goldfish_dialogue_2
  lines:
  - speakerName: "C\xE1 v\xE0ng"
    text: "\xD4ng l\xE3o\u2026 ta th\u1EA5y \xF4ng \u0111\xE3 l\xE0m quen v\u1EDBi
      v\xF9ng bi\u1EC3n \u1EDF V\u1ECBnh Xanh."
    portrait: {fileID: 21300000, guid: f4b768a7b2ec0014cb896764dc4ec3ef, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "C\xE1 v\xE0ng"
    text: "\xD4ng \u0111\xE3 b\u1EAFt \u0111\u01B0\u1EE3c kh\xE1 nhi\u1EC1u c\xE1."
    portrait: {fileID: 21300000, guid: f4b768a7b2ec0014cb896764dc4ec3ef, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "\xD4ng L\xE3o"
    text: "\u0110\xFAng v\u1EADy. Nh\u1EDD v\xF9ng bi\u1EC3n \u0111\xF3 m\xE0 ta
      c\xF3 th\u1EC3 ki\u1EBFm \u0111\u01B0\u1EE3c \xEDt ti\u1EC1n."
    portrait: {fileID: 21300000, guid: 23435321e5ba75444bd6bd462935adf3, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "C\xE1 v\xE0ng"
    text: "Nh\u01B0ng \u0111\xF3 ch\u1EC9 l\xE0 n\u01A1i d\xE0nh cho nh\u1EEFng ng\u01B0
      d\xE2n m\u1EDBi b\u1EAFt \u0111\u1EA7u."
    portrait: {fileID: 21300000, guid: f4b768a7b2ec0014cb896764dc4ec3ef, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "C\xE1 v\xE0ng"
    text: "C\xF3 nh\u1EEFng v\xF9ng bi\u1EC3n kh\xE1c nhi\u1EC1u c\xE1 h\u01A1n\u2026
      nh\u01B0ng c\u0169ng kh\xF3 \u0111\xE1nh b\u1EAFt h\u01A1n."
    portrait: {fileID: 21300000, guid: f4b768a7b2ec0014cb896764dc4ec3ef, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "\xD4ng L\xE3o"
    text: "V\u1EADy ta n\xEAn \u0111i \u0111\xE2u ti\u1EBFp theo?"
    portrait: {fileID: 21300000, guid: 23435321e5ba75444bd6bd462935adf3, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "C\xE1 v\xE0ng"
    text: "Ph\xEDa B\u1EAFc c\u1EE7a v\xF9ng bi\u1EC3n n\xE0y c\xF3 m\u1ED9t n\u01A1i
      g\u1ECDi l\xE0 \u0110\u1EA7m Tuy\u1EBFt."
    portrait: {fileID: 21300000, guid: f4b768a7b2ec0014cb896764dc4ec3ef, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "C\xE1 v\xE0ng"
    text: "Nh\u01B0ng trong \u0111\u1EA7m c\xF3 nhi\u1EC1u lo\u1EA1i c\xE1 kh\xE1c
      m\xE0 \xF4ng ch\u01B0a t\u1EEBng th\u1EA5y"
    portrait: {fileID: 21300000, guid: f4b768a7b2ec0014cb896764dc4ec3ef, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "C\xE1 v\xE0ng"
    text: "Tr\xEAn \u0111\u1EA3o c\xF3 m\u1ED9t ng\u01B0\u1EDDi s\u1ED1ng m\u1ED9t
      m\xECnh"
    portrait: {fileID: 21300000, guid: f4b768a7b2ec0014cb896764dc4ec3ef, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "C\xE1 v\xE0ng"
    text: "H\xE3y t\xECm \xF4ng \u1EA5y. \xD4ng \u1EA5y bi\u1EBFt r\xF5 v\xF9ng n\u01B0\u1EDBc
      \u1EDF \u0111\xF3."
    portrait: {fileID: 21300000, guid: f4b768a7b2ec0014cb896764dc4ec3ef, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "\xD4ng L\xE3o"
    text: "Ta hi\u1EC3u r\u1ED3i."
    portrait: {fileID: 21300000, guid: 23435321e5ba75444bd6bd462935adf3, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "C\xE1 v\xE0ng"
    text: "Chu\u1EA9n b\u1ECB t\u1ED1t tr\u01B0\u1EDBc khi \u0111i."
    portrait: {fileID: 21300000, guid: f4b768a7b2ec0014cb896764dc4ec3ef, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "C\xE1 v\xE0ng"
    text: "V\xF9ng n\u01B0\u1EDBc \u1EDF \u0111\xF3 s\xE2u v\xE0 kh\xF3 c\xE2u h\u01A1n."
    portrait: {fileID: 21300000, guid: f4b768a7b2ec0014cb896764dc4ec3ef, type: 3}
    setFlagAfter: ready_quest_2
    triggerQuestID: 
    triggerID: village
