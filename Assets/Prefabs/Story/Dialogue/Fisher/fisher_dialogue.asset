%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0184bb0e6d60d664fb460ef3950717ee, type: 3}
  m_Name: fisher_dialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueID: fisher_dialogue
  lines:
  - speakerName: "Ng\u01B0 d\xE2n"
    text: "Ch\xE0o \xF4ng l\xE3o. Tr\xF4ng \xF4ng kh\xF4ng gi\u1ED1ng ng\u01B0\u1EDDi
      \u1EDF \u0111\u1EA3o n\xE0y."
    portrait: {fileID: 21300000, guid: 8b4bf688b69895545a90e115c6bf2643, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "\xD4ng L\xE3o"
    text: "Ta ch\u1EC9 l\xE0 m\u1ED9t ng\u01B0 d\xE2n \u0111ang t\xECm v\xF9ng bi\u1EC3n
      c\xF3 nhi\u1EC1u c\xE1 h\u01A1n."
    portrait: {fileID: 21300000, guid: 23435321e5ba75444bd6bd462935adf3, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "Ng\u01B0 d\xE2n"
    text: "\xD4ng \u0111\u1EBFn \u0111\xFAng ch\u1ED7 r\u1ED3i."
    portrait: {fileID: 21300000, guid: 8b4bf688b69895545a90e115c6bf2643, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "Ng\u01B0 d\xE2n"
    text: "V\u1ECBnh Xanh l\xE0 n\u01A1i t\u1ED1t \u0111\u1EC3 b\u1EAFt \u0111\u1EA7u."
    portrait: {fileID: 21300000, guid: 8b4bf688b69895545a90e115c6bf2643, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "Ng\u01B0 d\xE2n"
    text: "\u1EDE v\xF9ng n\u01B0\u1EDBc quanh \u0111\u1EA3o c\xF3 r\u1EA5t nhi\u1EC1u
      c\xE1 nh\u1ECF. Ng\u01B0 d\xE2n th\u01B0\u1EDDng ra \u0111\xF3 \u0111\u1EC3
      ki\u1EBFm ti\u1EC1n tr\u01B0\u1EDBc khi \u0111i \u0111\u1EBFn nh\u1EEFng v\xF9ng
      bi\u1EC3n xa h\u01A1n."
    portrait: {fileID: 21300000, guid: 8b4bf688b69895545a90e115c6bf2643, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "\xD4ng L\xE3o"
    text: "Ta c\xF3 th\u1EC3 \u0111\xE1nh c\xE1 \u1EDF \u0111\xE2y ch\u1EE9?"
    portrait: {fileID: 21300000, guid: 23435321e5ba75444bd6bd462935adf3, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "Ng\u01B0 d\xE2n"
    text: "T\u1EA5t nhi\xEAn."
    portrait: {fileID: 21300000, guid: 8b4bf688b69895545a90e115c6bf2643, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "Ng\u01B0 d\xE2n"
    text: "N\u1EBFu \xF4ng mu\u1ED1n ki\u1EBFm ti\u1EC1n, h\xE3y ra kh\u01A1i v\xE0
      c\xE2u c\xE1."
    portrait: {fileID: 21300000, guid: 8b4bf688b69895545a90e115c6bf2643, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: "Ng\u01B0 d\xE2n"
    text: "Sau \u0111\xF3 mang c\xE1 v\u1EC1 \u0111\xE2y, t\xF4i s\u1EBD gi\xFAp
      \xF4ng b\xE1n ch\xFAng."
    portrait: {fileID: 21300000, guid: 8b4bf688b69895545a90e115c6bf2643, type: 3}
    setFlagAfter: 
    triggerQuestID: quest_1
    triggerID: hide
